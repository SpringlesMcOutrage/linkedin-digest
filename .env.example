# ── Flask ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-random-secret-key-here
DEBUG=false

# Secret shared with Salesforce to sign webhook requests (any random string)
WEBHOOK_SECRET=your-webhook-secret-here

# ── LinkedIn ────────────────────────────────────────────────────────────────
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=yourpassword
LINKEDIN_COOKIES_FILE=data/linkedin_cookies.json

# ── NVIDIA / DeepSeek ───────────────────────────────────────────────────────
# Get from: https://build.nvidia.com/  →  Get API Key
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx

# ── Salesforce ──────────────────────────────────────────────────────────────
# Your org URL (no trailing slash)
SF_INSTANCE_URL=https://yourorg.my.salesforce.com

# Connected App credentials (Setup → App Manager → New Connected App)
SF_CLIENT_ID=3MVG9...
SF_CLIENT_SECRET=ABC123...

# API user credentials
SF_USERNAME=api-user@yourorg.com
SF_PASSWORD=yourpassword
SF_SECURITY_TOKEN=yourtoken

# ── Pipeline settings ───────────────────────────────────────────────────────
MAX_POSTS_PER_RUN=50
DIGEST_LANGUAGE=Ukrainian
